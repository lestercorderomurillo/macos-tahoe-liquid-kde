<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>BlurEffectConfig</class>
 <widget class="QWidget" name="BlurEffectConfig">
  <property name="geometry">
   <rect><x>0</x><y>0</y><width>480</width><height>420</height></rect>
  </property>
  <layout class="QVBoxLayout">
   <item>
    <widget class="QLabel">
     <property name="text"><string>Acrylic Glass — blur and rounded corners for KDE Plasma 6.</string></property>
     <property name="wordWrap"><bool>true</bool></property>
    </widget>
   </item>
   <item>
    <widget class="QGroupBox">
     <property name="title"><string>Glass</string></property>
     <layout class="QFormLayout">
      <item row="0" column="0">
       <widget class="QLabel">
        <property name="text"><string>Blur strength</string></property>
        <property name="toolTip"><string>Kawase downsample depth. Higher values produce a deeper, more Gaussian-looking blur behind the glass.</string></property>
       </widget>
      </item>
      <item row="0" column="1">
       <widget class="QDoubleSpinBox" name="kcfg_BlurStrength">
        <property name="toolTip"><string>Kawase downsample depth. Higher values produce a deeper blur. Fractional values (e.g. 1.75) interpolate smoothly between levels.</string></property>
        <property name="minimum"><double>1.0</double></property>
        <property name="maximum"><double>20.0</double></property>
        <property name="singleStep"><double>0.05</double></property>
        <property name="decimals"><number>2</number></property>
       </widget>
      </item>
      <item row="1" column="0">
       <widget class="QLabel">
        <property name="text"><string>RGB drift (px)</string></property>
        <property name="toolTip"><string>Chromatic aberration spread at the glass rim. Dispersive glass separates wavelengths — red drifts outward, blue drifts inward. 0 = no drift.</string></property>
       </widget>
      </item>
      <item row="1" column="1">
       <widget class="QDoubleSpinBox" name="kcfg_RgbDriftStrength">
        <property name="toolTip"><string>Chromatic aberration spread at the glass rim. Dispersive glass separates wavelengths — red drifts outward, blue drifts inward. 0 = no drift.</string></property>
        <property name="minimum"><double>0.0</double></property>
        <property name="maximum"><double>100.0</double></property>
        <property name="singleStep"><double>1.0</double></property>
        <property name="decimals"><number>1</number></property>
       </widget>
      </item>
      <item row="2" column="0">
       <widget class="QLabel">
        <property name="text"><string>Lens magnify</string></property>
        <property name="toolTip"><string>Convex-lens magnification of the blurred backdrop. The whole glass surface acts as a thick lens — higher values make the background appear closer.</string></property>
       </widget>
      </item>
      <item row="2" column="1">
       <widget class="QDoubleSpinBox" name="kcfg_MagnifyGlassStrength">
        <property name="toolTip"><string>Convex-lens magnification of the blurred backdrop. The whole glass surface acts as a thick lens — higher values make the background appear closer.</string></property>
        <property name="minimum"><double>0.0</double></property>
        <property name="maximum"><double>0.1</double></property>
        <property name="singleStep"><double>0.001</double></property>
        <property name="decimals"><number>4</number></property>
       </widget>
      </item>
      <item row="3" column="0">
       <widget class="QLabel">
        <property name="text"><string>Refraction width (px)</string></property>
        <property name="toolTip"><string>Band from the glass edge inward where chromatic dispersion and lens distortion are active. Narrow values (e.g. 22 px) keep the prismatic fringe tight to the border.</string></property>
       </widget>
      </item>
      <item row="3" column="1">
       <widget class="QDoubleSpinBox" name="kcfg_RefractionWidth">
        <property name="toolTip"><string>Band from the glass edge inward where chromatic dispersion and lens distortion are active. Narrow values (e.g. 22 px) keep the prismatic fringe tight to the border.</string></property>
        <property name="minimum"><double>0.0</double></property>
        <property name="maximum"><double>300.0</double></property>
        <property name="singleStep"><double>1.0</double></property>
        <property name="decimals"><number>1</number></property>
       </widget>
      </item>
      <item row="4" column="0">
       <widget class="QLabel">
        <property name="text"><string>Highlight width (px)</string></property>
        <property name="toolTip"><string>Band from the glass edge inward where the specular glow and ambient top/bottom gradient are active. Large values (e.g. 120 px) spread the light across most of the surface.</string></property>
       </widget>
      </item>
      <item row="4" column="1">
       <widget class="QDoubleSpinBox" name="kcfg_HighlightWidth">
        <property name="toolTip"><string>Band from the glass edge inward where the specular glow and ambient top/bottom gradient are active. Large values (e.g. 120 px) spread the light across most of the surface.</string></property>
        <property name="minimum"><double>0.0</double></property>
        <property name="maximum"><double>600.0</double></property>
        <property name="singleStep"><double>1.0</double></property>
        <property name="decimals"><number>1</number></property>
       </widget>
      </item>
      <item row="5" column="0">
       <widget class="QLabel">
        <property name="text"><string>Highlight strength</string></property>
        <property name="toolTip"><string>Brightness multiplier for the specular rim glow at the glass edge. 0 = no highlight, 1 = default, 2+ = very bright.</string></property>
       </widget>
      </item>
      <item row="5" column="1">
       <widget class="QDoubleSpinBox" name="kcfg_HighlightStrength">
        <property name="toolTip"><string>Brightness multiplier for the specular rim glow at the glass edge. 0 = no highlight, 1 = default, 2+ = very bright.</string></property>
        <property name="minimum"><double>0.0</double></property>
        <property name="maximum"><double>3.0</double></property>
        <property name="singleStep"><double>0.05</double></property>
        <property name="decimals"><number>2</number></property>
       </widget>
      </item>
      <item row="6" column="0">
       <widget class="QLabel">
        <property name="text"><string>Shadow strength</string></property>
        <property name="toolTip"><string>Intensity of the ambient top-to-bottom gradient within the highlight width band. Brighter top, slightly darker bottom — as if lit from above.</string></property>
       </widget>
      </item>
      <item row="6" column="1">
       <widget class="QDoubleSpinBox" name="kcfg_ShadowStrength">
        <property name="toolTip"><string>Intensity of the ambient top-to-bottom gradient within the highlight width band. Brighter top, slightly darker bottom — as if lit from above.</string></property>
        <property name="minimum"><double>0.0</double></property>
        <property name="maximum"><double>3.0</double></property>
        <property name="singleStep"><double>0.05</double></property>
        <property name="decimals"><number>2</number></property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
   <item>
    <widget class="QGroupBox">
     <property name="title"><string>Options</string></property>
     <layout class="QVBoxLayout">
      <item>
       <widget class="QCheckBox" name="kcfg_TransparentBlur">
        <property name="text"><string>Enable blur (windows and decorations)</string></property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
   <item>
    <widget class="QGroupBox">
     <property name="title"><string>Force blur</string></property>
     <layout class="QVBoxLayout">
      <item>
       <widget class="QPlainTextEdit" name="kcfg_WindowClasses">
        <property name="maximumSize"><size><width>16777215</width><height>80</height></size></property>
       </widget>
      </item>
      <item>
       <layout class="QHBoxLayout">
        <item><widget class="QRadioButton" name="kcfg_BlurMatching"><property name="text"><string>Only matching</string></property></widget></item>
        <item><widget class="QRadioButton" name="kcfg_BlurNonMatching"><property name="text"><string>All except matching</string></property></widget></item>
       </layout>
      </item>
     </layout>
    </widget>
   </item>
   <item>
    <widget class="QGroupBox">
