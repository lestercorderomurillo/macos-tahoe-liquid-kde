<?xml version="1.0" encoding="UTF-8"?>
<kcfg xmlns="http://www.kde.org/standards/kcfg/2.0"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://www.kde.org/standards/kcfg/2.0
                          http://www.kde.org/standards/kcfg/2.0/kcfg.xsd">
  <kcfgfile name=""/>
  <group name="General">
    <entry name="menuIcon" type="String">
      <default>start-here-kde-symbolic</default>
    </entry>
    <entry name="useSystemFont" type="Bool">
      <default>false</default>
    </entry>
    <entry name="cmdSleep" type="String">
      <default>qdbus6 org.kde.Solid.PowerManagement /org/kde/Solid/PowerManagement requestSuspend || systemctl suspend</default>
    </entry>
    <entry name="cmdRestart" type="String">
      <default>qdbus6 org.kde.LogoutPrompt /LogoutPrompt org.kde.LogoutPrompt.promptReboot</default>
    </entry>
    <entry name="cmdShutDown" type="String">
      <default>qdbus6 org.kde.LogoutPrompt /LogoutPrompt org.kde.LogoutPrompt.promptShutDown</default>
    </entry>
    <entry name="cmdLockScreen" type="String">
      <default>qdbus6 org.freedesktop.ScreenSaver /ScreenSaver Lock || loginctl lock-session</default>
    </entry>
    <entry name="cmdLogOut" type="String">
      <default>qdbus6 org.kde.LogoutPrompt /LogoutPrompt org.kde.LogoutPrompt.promptLogout</default>
    </entry>
  </group>
</kcfg>
